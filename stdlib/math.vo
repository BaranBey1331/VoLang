fn multiply(a, b) {
return a * b;
}
‚Äčfn divide(a, b) {
return a / b;
}
‚Äčfn modulo(a, b) {
return a % b;
}
‚Äčfn square(x) {
return x * x;
}
‚Äčfn cube(x) {
return x * x * x;
}
‚Äčfn average(a, b) {
let sum = a + b;
return sum / 2;
}
‚Äčfn percent(value, total) {
let part = value * 100;
return part / total;
}
