# Compilers
CC = gcc
CXX = g++

# Flags (-I"src/H_files" automatically finds headers)
CFLAGS = -Wall -Wextra -O3 -std=c11 -I"src/H_files"
CXXFLAGS = -Wall -Wextra -O3 -std=c++17 -I"src/H_files"

# Directories
SRC_DIR = src/C_files
OBJ_DIR = obj

# Find all C and C++ files
C_SRCS = $(wildcard $(SRC_DIR)/*.c)
CXX_SRCS = $(wildcard $(SRC_DIR)/*.cpp)

# Object files corresponding to source files
OBJS = $(patsubst $(SRC_DIR)/%.c, $(OBJ_DIR)/%.o, $(C_SRCS)) \
       $(patsubst $(SRC_DIR)/%.cpp, $(OBJ_DIR)/%.o, $(CXX_SRCS))

TARGET = volang

# Default rule
all: $(TARGET)

# Linking everything together (using g++ for linking if C++ is present)
$(TARGET): $(OBJS)
	$(CXX) -o $@ $^

# Compiling C files
$(OBJ_DIR)/%.o: $(SRC_DIR)/%.c
	@mkdir -p $(OBJ_DIR)
	$(CC) $(CFLAGS) -c $< -o $@

# Compiling C++ files
$(OBJ_DIR)/%.o: $(SRC_DIR)/%.cpp
	@mkdir -p $(OBJ_DIR)
	$(CXX) $(CXXFLAGS) -c $< -o $@

# Clean up
clean:
	rm -rf $(OBJ_DIR) $(TARGET)

.PHONY: all clean
